<?xml version="1.0" encoding="UTF-8"?>
<!-- Minimal WiX definition for the Moonlit native apps. Built by
     packaging/build-windows.ps1 when WiX (candle/light) is on PATH.
     Pass -dVersion and -dStageDir from candle. -->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="Moonlit Native Suite"
           Language="1033"
           Version="$(var.Version)"
           Manufacturer="Moonlit"
           UpgradeCode="6F2B1E54-9C3A-4D8B-9E21-7A0C4D2F1B33">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Moonlit is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="Moonlit" Level="1">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentRef Id="ApplicationShortcuts" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Moonlit" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppProgramMenuDir" Name="Moonlit" />
      </Directory>
    </Directory>

    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <Component Id="DocForgeExe" Guid="*">
        <File Id="DocForgeExe" Source="$(var.StageDir)\moonlit-docforge.exe" KeyPath="yes" />
      </Component>
      <Component Id="AgentIdeExe" Guid="*">
        <File Id="AgentIdeExe" Source="$(var.StageDir)\moonlit-agent-ide.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Component Id="ApplicationShortcuts" Directory="AppProgramMenuDir" Guid="*">
      <Shortcut Id="DocForgeShortcut" Name="DocForge" Target="[INSTALLFOLDER]moonlit-docforge.exe" WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="AgentIdeShortcut" Name="Agent IDE" Target="[INSTALLFOLDER]moonlit-agent-ide.exe" WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="AppProgramMenuDir" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\Moonlit" Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <UIRef Id="WixUI_Minimal" />
  </Product>
</Wix>
